# Ollama 서버 주소 (로컬 기본값)
OLLAMA_BASE_URL=http://localhost:11434

# 사용할 Ollama 모델명 (ollama pull <모델명> 으로 설치 필요)
OLLAMA_MODEL=llama3

# Ollama 요청 타임아웃 (초 단위)
OLLAMA_TIMEOUT=120.0

# 프론트엔드 주소 (CORS 허용 대상)
FRONTEND_ORIGIN=http://localhost:3000

# 이 글자 수를 초과하면 chunk 분할 요약으로 전환합니다.
CHUNK_THRESHOLD=1500

# chunk당 목표 글자 수 (단락/문장 경계 우선, 이 크기에 가깝게 분할)
TARGET_CHUNK_SIZE=1000

# 허용하는 최대 chunk 수. 초과 시 에러를 반환합니다.
MAX_CHUNKS=10

# Oracle DB 접속 정보
ORACLE_USER=your_db_user
ORACLE_PASSWORD=your_db_password
ORACLE_DSN=localhost:1521/XEPDB1

# JWT 설정
# JWT_SECRET_KEY: 충분히 길고 무작위한 문자열로 교체하세요 (32자 이상 권장)
JWT_SECRET_KEY=change-this-to-a-long-random-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
